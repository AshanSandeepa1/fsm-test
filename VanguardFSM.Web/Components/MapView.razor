@inject IJSRuntime JS

<div id="map" style="height: 400px; width: 100%; border-radius: 8px;"></div>

@code {
    [Parameter] public double Lat { get; set; } = 51.5074;
    [Parameter] public double Lng { get; set; } = -0.1278;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("mapInterop.initialize", "map", Lat, Lng);
        }
    }

    public async Task AddWorkerMarker(double lat, double lng, string name, bool isClose)
    {
        string color = isClose ? "green" : "red";
        await JS.InvokeVoidAsync("mapInterop.addMarker", lat, lng, name, color);
    }
}