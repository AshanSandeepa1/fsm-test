@page "/dashboard"
@using VanguardFSM.Shared.Models
@using VanguardFSM.Web.Components
@inject HttpClient Http

<h3>Dispatcher Dashboard</h3>

@if (tasks == null)
{
    <p><em>Loading tasks...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in tasks)
            {
                <tr>
                    <td>@task.Title</td>
                    <td>@task.Status</td>
                    <td>
                        <button class="btn btn-primary" @onclick="() => DispatchTask(task.Id)">
                            Find Nearby Workers
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="alert @(dbStatus == "Online" ? "alert-success" : "alert-danger") shadow-sm">
    <strong>DB Status:</strong> @dbStatus | 
    <strong>Live Tasks in DB:</strong> @taskCount | 
    <small>Last Checked: @lastChecked</small>
</div>

@code {
    private MapView? mapComponent;
    private List<TaskItem>? tasks;
    private string dbStatus = "Checking...";
    private int taskCount = 0;
    private string lastChecked = "";

    protected override async Task OnInitializedAsync()
    {
        await RefreshDbStatus();
        // Fetch tasks from your API
        tasks = await Http.GetFromJsonAsync<List<TaskItem>>("api/Dispatch/tasks");
    }

    private async Task DispatchTask(int taskId)
    {
        // 1. Call the API to find workers within 5km (5000 meters)
        var nearbyWorkers = await Http.GetFromJsonAsync<List<User>>($"api/Dispatch/suggest-workers/{taskId}/5000");

        if (nearbyWorkers != null && mapComponent != null)
        {
            foreach (var worker in nearbyWorkers)
            {
                // 2. Plot them on the map
                // Note: We use .X for Longitude and .Y for Latitude from NetTopologySuite
                if (worker.LastKnownLocation != null)
                {
                    await mapComponent.AddWorkerMarker(
                        worker.LastKnownLocation.Y, 
                        worker.LastKnownLocation.X, 
                        worker.Name, 
                        true);
                }
            }
        }
    }
    private async Task RefreshDbStatus()
    {
        try {
            var result = await Http.GetFromJsonAsync<DbCheckResponse>("api/Dispatch/db-check");
            if (result != null) {
                dbStatus = result.Status;
                taskCount = result.TotalTasks;
                lastChecked = result.Timestamp;
            }
        } catch {
            dbStatus = "Offline";
        }
    }

    public class DbCheckResponse {
        public string Status { get; set; } = "";
        public int TotalTasks { get; set; }
        public string Timestamp { get; set; } = "";
    }
}